{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "drizzle.config.ts",
    "vitest.config.ts",
    "eslint.config.js",
    "build.mjs",
    "scripts/url-history.ts",
    "scripts/crawler-queue.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
