#----------------------------------------------------------------------
# Environment Configuration
#
# This file provides a template for the environment variables required
# by the application. Copy this file to .env and fill in the values.
#----------------------------------------------------------------------

# -- Application Settings --
# The environment the application is running in (e.g., development, production)
NODE_ENV=test

# The port the server will listen on
PORT=3001

# -- Database --
# The connection string for your PostgreSQL database.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_db_test"

# -- CORS --
# A comma-separated list of allowed origins for Cross-Origin Resource Sharing.
# Example: "http://localhost:3001,https://your-frontend-domain.com"
ALLOWED_ORIGINS="http://localhost:3001"

# -- Logging --
# The minimum level of logs to output (e.g., info, debug, warn, error).
LOG_LEVEL=error