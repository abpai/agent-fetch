# Use an official Node.js runtime as a parent image
FROM node:22-slim

# Set the working directory in the container
WORKDIR /usr/src/app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

# Copy package.json and pnpm-lock.yaml
COPY package.json pnpm-lock.yaml ./

# Install all dependencies (including devDependencies)
RUN pnpm install --frozen-lockfile

# Copy the rest of the application code
# This will be overridden by a volume mount in docker-compose for local development
COPY . .

# Expose the port the app runs on
EXPOSE 3000

# Default command to start the development server with hot-reloading
# This assumes you have a "dev" script in your package.json like "nodemon src/server.ts"
CMD ["pnpm", "run", "dev"]