# Application Settings
NODE_ENV=development
PORT=3000

# CORS
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000"

# Logging
# trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://crawl:crawl@localhost:5432/crawl

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# Tracks integration (activity monitoring)
# Path to Tracks raw NDJSON logs directory
TRACKS_RAW_DIR=~/.tracks/raw

# Optional Scrape.do queue worker
REDIS_URL=redis://localhost:6379
SCRAPEDO_TOKEN=your-scrapedo-token
INPUT_FILE=./data/url_queue_urls.txt
OUT_DIR=./out
BLACKLIST_DOMAINS_FILE=./data/blacklist_domains.txt
CONCURRENCY=5
LOCAL_TIMEOUT_MS=20000
SCRAPEDO_TIMEOUT_MS=60000
MIN_TEXT_CHARS=800
MAX_HTML_BYTES_FOR_LOCAL=2500000

# Scrape.do tuning (all optional)
SCRAPEDO_SUPER=false
SCRAPEDO_GEO_CODE=
SCRAPEDO_CUSTOM_HEADERS=false
SCRAPEDO_EXTRA_HEADERS=false
SCRAPEDO_FORWARD_HEADERS=false
SCRAPEDO_BLOCK_RESOURCES=
SCRAPEDO_CUSTOM_WAIT_MS=
SCRAPEDO_RENDER_ON_BLOCK=false
SCRAPEDO_RENDER_UNBLOCK=false
SCRAPEDO_HEADERS_JSON=
